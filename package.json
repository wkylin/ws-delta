{
  "name": "ws-realtime",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:frontend": "vite --host 0.0.0.0 --port 5180",
    "dev:server": "tsx watch server/src/index.ts",
    "server": "tsx server/src/index.ts",
    "test": "tsx --test tests/*.test.ts",
    "benchmark": "tsx scripts/benchmark-index.ts",
    "build": "vite build",
    "typecheck": "vue-tsc --noEmit -p tsconfig.json && tsc --noEmit -p server/tsconfig.json"
  },
  "dependencies": {
    "@koa/router": "^15.7.0",
    "ioredis": "^5.11.1",
    "kafkajs": "^2.2.4",
    "koa": "^3.2.1",
    "koa-bodyparser": "^4.4.1",
    "lucide-vue-next": "^0.577.0",
    "prom-client": "^15.1.3",
    "vue": "^3.5.29",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/koa": "^3.0.3",
    "@types/koa-bodyparser": "^4.3.1",
    "@types/koa__router": "^12.0.5",
    "@types/node": "^25.3.5",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-vue": "^6.0.4",
    "tsx": "^4.19.3",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vue-tsc": "^3.2.6"
  }
}
